APP_ENV=local
PORT=8080

# Local Docker Postgres default:
DATABASE_URL=postgres://checkinme:checkinme@localhost:5432/checkinme?sslmode=disable

# Supabase production example:
# Use Supabase Dashboard > Connect > Session pooler, usually port 5432.
# Example only. Replace project ref, region, password, and host.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

JWT_SECRET=change-this-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
DEVICE_WEBHOOK_SECRET=change-this-device-webhook-secret
DEFAULT_TIMEZONE=Asia/Phnom_Penh
AUTO_MIGRATE=true

# Optional bank payout adapter. Keep manual_csv until your bank gives API docs/credentials.
BANK_PROVIDER=manual_csv
BANK_API_BASE_URL=
BANK_API_KEY=

# PostgreSQL/Supabase pool tuning. Keep these conservative on Supabase free/small projects.
DB_MAX_CONNS=8
DB_MIN_CONNS=1
DB_MAX_CONN_IDLE_MINUTES=5

# Use auto for direct/session pooler. Use simple_protocol only for transaction pooler port 6543.
DB_QUERY_EXEC_MODE=auto

# Performance V2
REQUEST_TIMEOUT_SECONDS=15
SLOW_REQUEST_MS=700
CACHE_TTL_SECONDS=60
ASYNC_WORKER_LIMIT=8

# Attendance Anti-Fraud V2
FRAUD_WARN_SCORE=40
FRAUD_BLOCK_SCORE=100
FRAUD_MAX_SPEED_KPH=180
FRAUD_MAX_GPS_ACCURACY_M=80
FRAUD_DUPLICATE_SECONDS=120
