APP_ENV=local
PORT=8080
DATABASE_URL=postgres://checkinme:checkinme@localhost:5432/checkinme?sslmode=disable
JWT_SECRET=change-this-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
DEVICE_WEBHOOK_SECRET=change-this-device-webhook-secret
DEFAULT_TIMEZONE=Asia/Phnom_Penh

# Optional bank payout adapter. Keep manual_csv until your bank gives API docs/credentials.
BANK_PROVIDER=manual_csv
BANK_API_BASE_URL=
BANK_API_KEY=

# PostgreSQL pool tuning
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_IDLE_MINUTES=10

REQUEST_TIMEOUT_SECONDS=15
SLOW_REQUEST_MS=700
CACHE_TTL_SECONDS=60
ASYNC_WORKER_LIMIT=8

FRAUD_WARN_SCORE=40
FRAUD_BLOCK_SCORE=100
FRAUD_MAX_SPEED_KPH=180
FRAUD_MAX_GPS_ACCURACY_M=80
FRAUD_DUPLICATE_SECONDS=120