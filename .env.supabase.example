APP_ENV=production
PORT=10000

# Recommended: Supabase Session pooler string, port 5432, SSL required.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# If you use Supabase Transaction pooler on port 6543, set:
# DB_QUERY_EXEC_MODE=simple_protocol
DB_QUERY_EXEC_MODE=auto
# Use a dedicated schema on Supabase so CheckinMe will not collide with existing public.users or other app tables.
DB_SCHEMA=checkinme

JWT_SECRET=replace-with-very-long-random-secret-at-least-32-chars
DEVICE_WEBHOOK_SECRET=replace-with-very-long-device-webhook-secret
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
DEFAULT_TIMEZONE=Asia/Phnom_Penh
AUTO_MIGRATE=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
BANK_PROVIDER=manual_csv
BANK_API_BASE_URL=
BANK_API_KEY=

DB_MAX_CONNS=8
DB_MIN_CONNS=1
DB_MAX_CONN_IDLE_MINUTES=5
REQUEST_TIMEOUT_SECONDS=15
SLOW_REQUEST_MS=700
CACHE_TTL_SECONDS=60
ASYNC_WORKER_LIMIT=6
FRAUD_WARN_SCORE=40
FRAUD_BLOCK_SCORE=100
FRAUD_MAX_SPEED_KPH=180
FRAUD_MAX_GPS_ACCURACY_M=80
FRAUD_DUPLICATE_SECONDS=120
